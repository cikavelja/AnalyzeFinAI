# AnalizerAI — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# OpenAI / LLM
# ---------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here  # Required for OpenAI provider
OPENAI_MODEL=gpt-4o                    # Model to use (default: gpt-4o)

# ---------------------------------------------------------------------------
# Local / HuggingFace LLM
# ---------------------------------------------------------------------------
# "openai"  — use the OpenAI API (default)
# "local"   — use a locally downloaded HuggingFace model
LLM_PROVIDER=openai

# Default local model when LLM_PROVIDER=local
LOCAL_MODEL_ID=microsoft/Phi-3.5-mini-instruct

# HuggingFace token — required for gated models (Llama, Gemma, etc.)
HF_TOKEN=

# Directory where local model weights are cached
HF_CACHE_DIR=data/models

# ---------------------------------------------------------------------------
# Conversion mode
# ---------------------------------------------------------------------------
# "local"  — use the built-in LocalConverter (no external service needed)
# "mcp"    — delegate to the MarkItDown MCP server
CONVERSION_MODE=local

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR

# ---------------------------------------------------------------------------
# Audit
# ---------------------------------------------------------------------------
AUDIT_LOG_PATH=data/audit.jsonl        # Path to the append-only audit log

# ---------------------------------------------------------------------------
# Safety switches
# ---------------------------------------------------------------------------
LOCAL_ONLY_MODE=false                  # When true, all network calls are blocked
